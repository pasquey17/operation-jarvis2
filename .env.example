ANTHROPIC_API_KEY=sk-ant-api03-...

# Notion → public.trades sync (POST data_sources/.../query)
NOTION_API_KEY=secret_...
# Optional override (default matches your data source id)
# NOTION_DATA_SOURCE_ID=262e0ffd0a52818abf00000bc795ba54

# Mum’s Notion integration (separate from NOTION_API_KEY — used only by notion-sync-mum.mjs)
NOTION_API_KEY_MUM=ntn_...
# Primary data source for mum (optional; has a default in notion-sync-mum.mjs)
# NOTION_DATA_SOURCE_ID_MUM=294f9844-43a9-82da-bfa3-07deb7d0693f
# Mum’s Notion database id — when set, sync merges every child data_source under this database
# NOTION_MUM_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Supabase — server reads/writes via public.trades (PostgREST names are case-sensitive)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
# Recommended for sync upserts (bypasses RLS). Falls back to SUPABASE_ANON_KEY if unset.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: override the default table name
# SUPABASE_TABLE=trades
# Optional: max rows per request (default 5000)
# MAX_SUPABASE_ROWS=5000
